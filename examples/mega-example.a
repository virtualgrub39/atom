$println [ out "\r\n" out ]

1
[
    >I
    "I love Hatsune Miku x" <I string ++
    #println ! -- '!' is shorthand for 'eval'
    1 <I +
] 10 times
drop

$fib_linear [ 
    >N

    <N 2 lt if 
        1
    else [
        1 1
        [
            >B >A
            <B
            <B <A +
        ] <N 2 - times 
        nip
    ]
]

20 #fib_linear! #println!

$fib_rec [
    >N
    this >rec

    <N 2 lte -- if
    1 -- then
    [ <N 1 - <rec! <N 2- <rec! + ] -- else
    ifte -- postfix conditional. `ift` for no-else variant
]

20 #fib_rec! #println!

$nil? [ nil eq ]
$decons [ dup head >H tail <H ]

$reverse [
    () swap

    [ dup #nil?! not ]
    [
        #decons! swap
        >T :: <T
    ] whiledo

    drop
]

(1 2 3) #reverse! #println!
